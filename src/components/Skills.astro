---
import { skillGroups } from '../data/projects';
---

<section id="skills">
  <div class="container">
    <h2 class="section-title">Skills</h2>
    <div class="groups">
      {skillGroups.map((g) => (
        <div class="group">
          <h3>{g.name}</h3>
          <ul>
            {g.skills.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1.5rem;
  }
  .group {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .group h3 {
    font-size: 1.05rem;
    margin-bottom: 0.8rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  li {
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }
</style>
