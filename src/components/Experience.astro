---
import { experience } from '../data/projects';
---

<section id="experience">
  <div class="container">
    <h2 class="section-title">Experience</h2>
    <ol class="timeline">
      {experience.map((r) => (
        <li class:list={['entry', { current: r.current }]}>
          <div class="marker" aria-hidden="true"></div>
          <div class="body">
            <h3>{r.title} · <span class="company">{r.company}</span></h3>
            <span class="period">{r.period}</span>
            <p>{r.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--border);
  }
  .entry {
    position: relative;
    padding: 0 0 2rem 2.2rem;
  }
  .entry:last-child {
    padding-bottom: 0;
  }
  .marker {
    position: absolute;
    left: 0;
    top: 8px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg-raised);
    border: 2px solid var(--text-muted);
  }
  .entry.current .marker {
    border-color: var(--accent);
    box-shadow: 0 0 12px rgba(245, 158, 84, 0.5);
  }
  h3 {
    font-size: 1.15rem;
    margin-bottom: 0.15rem;
  }
  .company {
    background: var(--nebula);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .period {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  p {
    margin: 0.4rem 0 0;
    font-size: 0.95rem;
    max-width: 44rem;
  }
</style>
