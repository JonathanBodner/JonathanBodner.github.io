---
// Build-time generated starfield: three layers of box-shadow "stars",
// no runtime JS. Twinkle/drift animations are disabled by the global
// prefers-reduced-motion rule.
function stars(count: number, area = 2000) {
  return Array.from({ length: count }, () => {
    const x = Math.floor(Math.random() * area);
    const y = Math.floor(Math.random() * area);
    return `${x}px ${y}px #fff`;
  }).join(', ');
}
const small = stars(380);
const medium = stars(120);
const large = stars(45);
---

<div class="starfield" aria-hidden="true">
  <div class="stars s1"></div>
  <div class="stars s2"></div>
  <div class="stars s3"></div>
  <div class="nebula-glow"></div>
</div>

<style define:vars={{ small, medium, large }}>
  .starfield {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .stars {
    position: absolute;
    inset: 0;
  }
  .stars::after {
    content: '';
    position: absolute;
    width: 1px;
    height: 1px;
    border-radius: 50%;
    background: transparent;
  }
  .s1::after {
    box-shadow: var(--small);
    opacity: 0.5;
    animation: twinkle 5s ease-in-out infinite alternate;
  }
  .s2::after {
    width: 2px;
    height: 2px;
    box-shadow: var(--medium);
    opacity: 0.7;
    animation: twinkle 7s ease-in-out infinite alternate-reverse;
  }
  .s3::after {
    width: 3px;
    height: 3px;
    box-shadow: var(--large);
    opacity: 0.9;
    animation: twinkle 9s ease-in-out infinite alternate;
  }
  .nebula-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 45% at 75% 15%, rgba(139, 124, 247, 0.16), transparent 70%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(76, 201, 240, 0.1), transparent 70%);
  }
  @keyframes twinkle {
    from { opacity: 0.3; }
    to { opacity: 0.9; }
  }
</style>
